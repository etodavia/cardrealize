PORT=3000

# Use MariaDB in EasyPanel by setting DB_TYPE=mariadb and filling these values.
DB_TYPE=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_USER=cardrealize
DB_PASSWORD=change-me
DB_NAME=cardrealize

# Local fallback when MariaDB is not configured.
DB_FILE=database.sqlite

# Persist this folder with a volume in EasyPanel.
UPLOAD_DIR=uploads
